# App
APP_NAME=Autonomous AI Engine
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./engine.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/aiengine

# Vector store
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# For hosted proxy (ollamafreeapi):
# OLLAMA_BASE_URL=https://api.ollamafreeapi.com
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_API_KEY=

# Orchestration
MAX_CONCURRENT_TASKS=8
TASK_DEFAULT_RETRY_LIMIT=3