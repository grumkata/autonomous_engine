# ============================================================
#  Autonomous Engine — Environment Configuration
# ============================================================
#
# QUICK START (recommended):
#   1. Copy this file to .env
#   2. Set LLM_PROVIDER=auto
#   3. Add API keys for any providers you have (the more the better)
#   4. The engine will use ALL configured providers in parallel,
#      with MetaOrchestrator routing tasks to the best one.
#
# MINIMUM SETUP (completely free, no signup):
#   LLM_PROVIDER=auto
#   USE_POLLINATIONS=true   # keyless fallback
#   USE_LLM7=true           # keyless fallback
#
# RECOMMENDED SETUP (3 free signups, massive capacity):
#   LLM_PROVIDER=auto
#   GROQ_API_KEY=gsk_...          # groq.com     — fastest, meta-orchestrator
#   GOOGLE_API_KEY=AIza...        # ai.google.dev — most generous free tier
#   CEREBRAS_API_KEY=csk-...      # cerebras.ai  — 1M tok/day, ~1000 tok/s
#
# ============================================================

# ── Mode ─────────────────────────────────────────────────────
# "auto"  = use all keys below automatically (recommended)
# "pool"  = manual JSON config via LLM_POOL_CONFIG
# "ollama" / "groq" / "openrouter" = single provider
LLM_PROVIDER=auto

# ── Meta-orchestrator (routing brain) ────────────────────────
# A fast model that picks which provider handles each task (~100ms).
# Uses Groq by default — share the same key as GROQ_API_KEY.
META_ORCHESTRATOR_PROVIDER=groq
META_ORCHESTRATOR_MODEL=llama-3.1-8b-instant
META_ORCHESTRATOR_API_KEY=   # blank = reuse GROQ_API_KEY

# ── Speed tier (0 = fastest) ─────────────────────────────────
# instant: Groq, Cerebras  — 300-1000 tok/s, ideal for critique/qa
# fast:    SambaNova, Google, Together — 50-200 tok/s
# moderate: OpenRouter, Mistral, DeepSeek — 20-80 tok/s
# slow:   Ollama (local), HuggingFace — hardware-dependent

# ============================================================
#  FREE PROVIDERS — SIGN UP AT THE URLS BELOW
# ============================================================

# ── TIER 1: Instant (LPU/WSE hardware) ──────────────────────

# Groq — https://console.groq.com  (no credit card)
# Free: 30 RPM, 6K TPM, 14400 req/day | Speed: 300+ tok/s
# Models: llama-3.1-8b-instant, llama-3.3-70b, deepseek-r1, qwen-qwq-32b
GROQ_API_KEY=

# Cerebras — https://cloud.cerebras.ai  (no credit card)
# Free: 30 RPM, 60K TPM, 1M tok/day | Speed: ~1000 tok/s
# Models: llama3.1-8b, llama-3.3-70b, qwen-3-32b, qwen-3-235b
CEREBRAS_API_KEY=

# SambaNova — https://cloud.sambanova.ai  (persistent free, no expiry)
# Free: 10-30 RPM (size-dependent) | Speed: 294 tok/s
# Models: Llama-3.1-405B, Llama-3.3-70B, Qwen2.5-72B, DeepSeek-V3
SAMBANOVA_API_KEY=

# ── TIER 2: Smart (high-quality, generous quotas) ────────────

# Google AI Studio — https://ai.google.dev  (no credit card)
# Free: Flash 1500 req/day, 250K TPM | Context: 1M tokens | Multimodal
# Models: gemini-2.5-flash, gemini-2.0-flash, gemini-2.5-flash-lite
GOOGLE_API_KEY=

# NVIDIA NIM — https://build.nvidia.com  (NVIDIA Developer Program)
# Free: 1000 credits on signup, 40 RPM | 100+ models
# Models: Llama-3.1-405B, DeepSeek-R1/V3, Kimi-K2.5, GLM-4.7, GPT-OSS-120B
NVIDIA_API_KEY=

# Together AI — https://www.together.ai  ($25 free credits)
# Models: Llama-405B-Turbo, DeepSeek-R1/V3, Qwen2.5-72B, Mixtral-8x7B
TOGETHER_API_KEY=

# OpenRouter — https://openrouter.ai  (no credit card)
# Free: 200+ models with :free suffix | Gateway to everything
# Best free: deepseek/deepseek-r1:free, qwen/qwen3-235b:free
OPENROUTER_API_KEY=

# DeepSeek — https://platform.deepseek.com  (5M free tokens)
# Best coding/reasoning model. Very cheap beyond free tier.
# Models: deepseek-chat, deepseek-reasoner, deepseek-coder
DEEPSEEK_API_KEY=

# ── TIER 3: Specialist providers ─────────────────────────────

# Fireworks AI — https://fireworks.ai  (free credits)
# High RPM. Good for parallel/batch tasks.
FIREWORKS_API_KEY=

# Mistral AI — https://console.mistral.ai  (free trial)
# Strong coding (Codestral). European provider.
MISTRAL_API_KEY=

# GitHub Models — https://github.com/marketplace/models  (GitHub account)
# Free: 15 RPM, 150 req/day | GPT-4o-mini, DeepSeek-R1, Mistral
GITHUB_TOKEN=

# HuggingFace — https://huggingface.co  (create access token)
# Thousands of models. Cold starts on free tier.
HF_API_KEY=

# Hyperbolic AI — https://app.hyperbolic.xyz  ($10 free credits)
# Access to 405B and DeepSeek-R1 at low cost.
HYPERBOLIC_API_KEY=

# Novita AI — https://novita.ai  (free credits)
NOVITA_API_KEY=

# Nebius AI Studio — https://studio.nebius.ai  (European, free trial)
NEBIUS_API_KEY=

# Featherless AI — https://featherless.ai  (HuggingFace model hosting)
FEATHERLESS_API_KEY=

# Kluster AI — https://kluster.ai  (batch-optimised, free credits)
KLUSTER_API_KEY=

# SiliconFlow — https://cloud.siliconflow.cn  (Chinese, free tier)
# Strong Qwen and DeepSeek support.
SILICONFLOW_API_KEY=

# ── Asian providers ───────────────────────────────────────────

# Moonshot AI (Kimi) — https://platform.moonshot.cn  (free credits)
# 128K context. Kimi-K2 available.
MOONSHOT_API_KEY=

# Zhipu AI (GLM) — https://open.bigmodel.cn  (GLM-4-Flash is FREE)
# GLM-4-Flash requires no payment at all.
ZHIPU_API_KEY=

# ── Cloudflare Workers AI ─────────────────────────────────────
# Free: 10K req/day bundled with Workers | Edge-distributed
# Requires BOTH keys below.
CF_API_KEY=
CF_ACCOUNT_ID=

# ── Keyless providers (always on, no signup needed) ───────────
# These are automatically included in auto mode.
USE_POLLINATIONS=true   # pollinations.ai — completely anonymous
USE_LLM7=true           # llm7.io — 150 RPM, no key needed

# ── Ollama (local fallback) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=600

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./engine.db

# ── Orchestration ─────────────────────────────────────────────
MAX_CONCURRENT_TASKS=8
