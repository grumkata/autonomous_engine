# ============================================================================
# autonomous_engine — environment configuration
# Copy to .env and fill in the keys for providers you want to use.
# You ONLY need keys for providers listed in TIER*_PROVIDERS.
# ============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Autonomous AI Engine"
DEBUG=false
LOG_LEVEL=INFO

# ── Database / Vector store ───────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./engine.db
CHROMA_PERSIST_DIR=./chroma_data

# ============================================================================
# LLM MODE
# "single"  — one provider for everything
# "tiered"  — recommended: routes tasks cheapest-first
# ============================================================================
LLM_MODE=tiered
LLM_PROVIDER=groq   # used only when LLM_MODE=single

# ============================================================================
# TIER POOLS
# Comma-separated list of providers per tier.
# Providers with no API key set are silently skipped.
# Round-robin load balanced within each tier.
# Auto-escalation: attempt 2 → tier+1, attempt 3 → tier+2
# ============================================================================

# TIER 1 — Free, no practical limits (handles ~80% of all tasks)
TIER1_PROVIDERS=groq,cerebras,siliconflow,llm7,pollinations,ollama

# TIER 2 — Free, rate-limited (important tasks needing real capability)
TIER2_PROVIDERS=gemini,sambanova,openrouter,zhipu,mistral,huggingface

# TIER 3 — Paid (last resort; off by default)
TIER3_PROVIDERS=anthropic,deepseek,deepinfra
TIER3_ENABLED=false

# Quality threshold boundaries for tier assignment
TIER1_MAX_THRESHOLD=0.72
TIER2_MAX_THRESHOLD=0.84

# ============================================================================
# PROVIDER KEYS — TIER 1 (Free, unlimited)
# ============================================================================

# ── Ollama (local, zero cost) ─────────────────────────────────────────────────
# No key needed. Pull a model first: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

# ── Groq — fastest free inference (~300-800 tok/s) ───────────────────────────
# Sign up: console.groq.com — no credit card
# Free: 14,400 req/day on 8B, ~500/day on 70B
# Models: llama-3.1-8b-instant (tier 1), llama-3.3-70b-versatile (tier 2)
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# ── Cerebras — wafer-scale, 1000-2600 tok/s ──────────────────────────────────
# Sign up: cloud.cerebras.ai — no credit card
# Free: 1M tokens/day | Models: llama-3.3-70b, qwen3-32b, qwen3-235b
CEREBRAS_API_KEY=
CEREBRAS_DEFAULT_MODEL=llama-3.3-70b

# ── SiliconFlow — highest RPM of any free provider (1K RPM) ──────────────────
# Sign up: siliconflow.cn — free tier
# Free: 1K RPM / 50K TPM | Models: Qwen3-8B free permanently
SILICONFLOW_API_KEY=
SILICONFLOW_DEFAULT_MODEL=Qwen/Qwen3-8B

# ── LLM7.io — no API key required, 27+ models ────────────────────────────────
# No sign up needed. 30 RPM free, 120 RPM with account
LLM7_DEFAULT_MODEL=deepseek-ai/DeepSeek-R1

# ── Kluster AI — free Qwen3-235B, Llama 4, DeepSeek R1 ───────────────────────
# Sign up: kluster.ai — no credit card
KLUSTER_API_KEY=
KLUSTER_DEFAULT_MODEL=klusterai/Meta-Llama-3.3-70B-Instruct-Turbo

# ── BazaarLink — free multi-model router ─────────────────────────────────────
# Sign up: bazaarlink.ai — routes to GPT-4o/Claude/Gemini/etc for free
BAZAARLINK_API_KEY=
BAZAARLINK_DEFAULT_MODEL=auto:free

# ── Pollinations.ai — completely free, no key, no registration ───────────────
# Zero setup. Just add "pollinations" to TIER1_PROVIDERS.
POLLINATIONS_DEFAULT_MODEL=openai-large

# ── Ollama Cloud — same API as local Ollama, free session limits ──────────────
# Sign up: ollama.com
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_DEFAULT_MODEL=deepseek-v3.2

# ── Featherless.ai — 4000+ HuggingFace models serverless ─────────────────────
# Sign up: featherless.ai — free tier
FEATHERLESS_API_KEY=
FEATHERLESS_DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# ── GitHub Models — free for all GitHub users ────────────────────────────────
# Get key: github.com/marketplace/models — requires GitHub account
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_DEFAULT_MODEL=meta-llama-3.3-70b-instruct

# ── Hugging Face Inference API — 150K+ models, 2K req/day free ───────────────
# Get key: huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ============================================================================
# PROVIDER KEYS — TIER 2 (Free, rate-limited)
# ============================================================================

# ── Google Gemini — most generous free tier by token volume ──────────────────
# Get key: aistudio.google.com — no billing required
# Free: 2.5 Flash = 10 RPM / 250 RPD / 1M context; Flash-Lite = 1K RPD
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# ── SambaNova — third fastest free inference, RDU chips ──────────────────────
# Sign up: cloud.sambanova.ai — no credit card
# Free: 10-30 RPM | Models: Llama 3.3 70B, DeepSeek R1
SAMBANOVA_API_KEY=
SAMBANOVA_DEFAULT_MODEL=Meta-Llama-3.3-70B-Instruct

# ── OpenRouter — 300+ models, 30+ free :free models ──────────────────────────
# Sign up: openrouter.ai — free models need no payment
# Free: 20 RPM / 50 RPD (1K RPD after $10 lifetime)
# Best free: meta-llama/llama-3.3-70b-instruct:free, qwen/qwen3-235b:free
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Mistral — Experiment plan: 1B tokens/month free ──────────────────────────
# Sign up: console.mistral.ai — no credit card
MISTRAL_API_KEY=
MISTRAL_DEFAULT_MODEL=mistral-small-latest

# ── Cohere — 1K req/month free, best-in-class RAG/embeddings ─────────────────
# Get Trial key: cohere.com — no credit card
COHERE_API_KEY=
COHERE_DEFAULT_MODEL=command-r-plus

# ── NVIDIA NIM — 1K free credits, 40 RPM, H100-grade inference ───────────────
# Sign up: build.nvidia.com
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_DEFAULT_MODEL=meta/llama-3.3-70b-instruct

# ── Zhipu AI — GLM-4-Flash: free with NO published rate cap ──────────────────
# Sign up: open.bigmodel.cn — free Flash model
ZHIPU_API_KEY=
ZHIPU_DEFAULT_MODEL=glm-4-flash

# ── Moonshot (Kimi) — up to 1M context, best for long documents ──────────────
# Sign up: platform.moonshot.cn
MOONSHOT_API_KEY=
MOONSHOT_DEFAULT_MODEL=moonshot-v1-128k

# ── Together AI — 200+ models, :Free models available ────────────────────────
# Sign up: together.ai
TOGETHER_API_KEY=
TOGETHER_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# ── AI21 Labs — Jamba hybrid SSM-Transformer, 256K context ───────────────────
# Sign up: ai21.com — Experiment plan: ~1B tokens/month free
AI21_API_KEY=
AI21_DEFAULT_MODEL=jamba-1.6-mini

# ============================================================================
# PROVIDER KEYS — TIER 3 (Paid — only used when TIER3_ENABLED=true)
# ============================================================================

# ── Anthropic Claude — best quality, safety-focused ──────────────────────────
# Sign up: anthropic.com
# claude-haiku-4-5-20251001: $0.25/$1.25 per 1M tokens (cheapest Claude)
# claude-sonnet-4-6: $3/$15 per 1M tokens
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_SECONDS=120

# ── DeepSeek — near-free (~$0.07/1M input tokens) ────────────────────────────
# Sign up: platform.deepseek.com
# deepseek-chat (V3): best value; deepseek-reasoner (R1): best reasoning
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ── OpenAI — most widely supported, most expensive ───────────────────────────
# Sign up: platform.openai.com
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# ── xAI Grok — 2M context, real-time X/web search ───────────────────────────
# Sign up: console.x.ai
XAI_API_KEY=
XAI_DEFAULT_MODEL=grok-3-fast

# ── Fireworks AI — FireAttention 4x faster than vLLM, HIPAA/SOC2 ─────────────
# Sign up: fireworks.ai
FIREWORKS_API_KEY=
FIREWORKS_DEFAULT_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# ── Hyperbolic — up to 80% cheaper than AWS ───────────────────────────────────
# Sign up: hyperbolic.xyz
HYPERBOLIC_API_KEY=
HYPERBOLIC_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── DeepInfra — cheapest hosted open-source ($0.07/M for 8B) ─────────────────
# Sign up: deepinfra.com
DEEPINFRA_API_KEY=
DEEPINFRA_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── Perplexity Sonar — LLM + real-time web search + citations ────────────────
# Sign up: pplx.ai
PERPLEXITY_API_KEY=
PERPLEXITY_DEFAULT_MODEL=sonar

# ── AI/ML API — 300+ models unified (text+image+audio+video) ─────────────────
# Sign up: aimlapi.com
AIMLAPI_API_KEY=
AIMLAPI_DEFAULT_MODEL=gpt-4o

# ── 01.AI (Yi) — 200K context, strong bilingual Chinese-English ──────────────
# Sign up: platform.lingyiwanwu.com
YI_API_KEY=
YI_DEFAULT_MODEL=yi-large

# ── Alibaba Qwen — Qwen3-235B, best non-English languages ────────────────────
# Sign up: dashscope.aliyuncs.com
QWEN_API_KEY=
QWEN_DEFAULT_MODEL=qwen-plus

# ── Novita AI — multi-modal (LLM+image+video+speech), 50% cheaper ────────────
# Sign up: novita.ai
NOVITA_API_KEY=
NOVITA_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Lambda Labs — H100 clusters, transparent per-token pricing ───────────────
# Sign up: lambda.chat
LAMBDA_API_KEY=
LAMBDA_DEFAULT_MODEL=llama3.3-70b-instruct-fp8

# ============================================================================
# LOCAL PROVIDERS (add any to any tier — always free)
# These run on your own hardware. No API keys needed.
# All expose an OpenAI-compatible API.
# ============================================================================

# ── LM Studio (localhost:1234) ────────────────────────────────────────────────
# Download: lmstudio.ai — best GUI for local LLMs
# Add "lmstudio" to any TIER*_PROVIDERS list
LMSTUDIO_BASE_URL=http://localhost:1234

# ── Jan AI (localhost:1337) ───────────────────────────────────────────────────
# Download: jan.ai — open-source LM Studio alternative
JAN_BASE_URL=http://localhost:1337

# ── LocalAI (localhost:8080) ──────────────────────────────────────────────────
# GitHub: mudler/LocalAI — full OpenAI replacement (LLM+STT+TTS+images)
LOCALAI_BASE_URL=http://localhost:8080

# ── llama.cpp server (localhost:8080) ─────────────────────────────────────────
# GitHub: ggerganov/llama.cpp — raw fastest inference
LLAMACPP_BASE_URL=http://localhost:8080

# ── vLLM (localhost:8000) ────────────────────────────────────────────────────
# GitHub: vllm-project/vllm — production serving, best concurrent throughput
VLLM_BASE_URL=http://localhost:8000

# ── SGLang (localhost:30000) ──────────────────────────────────────────────────
# GitHub: sgl-project/sglang — fastest for structured output / agentic tasks
SGLANG_BASE_URL=http://localhost:30000

# ============================================================================
# VALIDATION TUNING
# ============================================================================
# 1.0 = full thresholds (for 70B+ or Claude-class models)
# 0.75 = 13B-30B models
# 0.60 = minimum viable for 7B local models
VALIDATION_SCORE_SCALE=1.0

# ============================================================================
# ORCHESTRATION
# ============================================================================
# Local Ollama only: 1-2. Fast cloud APIs: 4-8.
MAX_CONCURRENT_TASKS=4
TASK_DEFAULT_RETRY_LIMIT=3
