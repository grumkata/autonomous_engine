# ============================================================================
# autonomous_engine — environment configuration
# Copy this file to .env and fill in the values you want to use.
# Lines starting with # are comments and are ignored.
# ============================================================================


# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Autonomous AI Engine"
DEBUG=false
LOG_LEVEL=INFO


# ── LLM Mode ─────────────────────────────────────────────────────────────────
# "single"  — one provider does everything (simple, original behaviour)
# "tiered"  — routes tasks to cheapest capable provider (recommended)
LLM_MODE=tiered

# In "single" mode, which provider to use:
# Options: ollama | groq | openrouter | cerebras | sambanova | gemini | anthropic | deepseek
LLM_PROVIDER=groq


# ============================================================================
# TIERED MODE — Provider pools per tier
# ============================================================================
# Comma-separated list of providers for each tier.
# Providers whose API key is missing are silently skipped.
# Providers within a tier are load-balanced round-robin.
#
# Auto-escalation: if a task fails on attempt 1, attempt 2 uses Tier+1,
# attempt 3 uses Tier+2. Expensive models are only reached as last resort.
# ============================================================================

# ── TIER 1 — Free, unlimited ──────────────────────────────────────────────
# The workhorse. Handles all routine tasks: planning, research, drafts.
# Recommended mix: fast 8B model (Groq) + large 70B (Cerebras/SambaNova).
#
TIER1_PROVIDERS=groq,cerebras,ollama

# Which tasks land here: quality_threshold below TIER1_MAX_THRESHOLD
TIER1_MAX_THRESHOLD=0.72


# ── TIER 2 — Free, rate-limited ───────────────────────────────────────────
# For important tasks that need better capability.
# Gemini 1.5 Flash is the star: 15 RPM / 1,000,000 tokens/day completely free.
#
TIER2_PROVIDERS=gemini,sambanova,openrouter

# Which tasks land here: quality_threshold between tier1 and tier2 max
TIER2_MAX_THRESHOLD=0.84


# ── TIER 3 — Paid, opt-in ────────────────────────────────────────────────
# Only used for the hardest tasks or when tiers 1+2 both fail.
# TIER3_ENABLED=false means tier 3 is never called — safe for dev.
# Set to true when you're ready to spend a little for quality.
# DeepSeek is near-free ($0.07/1M tokens) — great budget tier 3 option.
#
TIER3_PROVIDERS=anthropic,deepseek
TIER3_ENABLED=false


# ============================================================================
# PROVIDER API KEYS + MODELS
# Add the keys for whichever providers you want to use.
# You only need the providers listed in TIER*_PROVIDERS above.
# ============================================================================


# ── Ollama (local, always free) ──────────────────────────────────────────
# Runs on your machine — no API key needed.
# Pull a model first: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
# OLLAMA_API_KEY=   # only needed for hosted Ollama proxies


# ── Groq (free, fast) ────────────────────────────────────────────────────
# Sign up: https://console.groq.com — no credit card
# Free limits: 14,400 req/day on 8B models, ~500/day on 70B
# Tier 1 recommended model: llama-3.1-8b-instant (very fast)
# Tier 2 recommended model: llama-3.3-70b-versatile (better quality)
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant


# ── Cerebras Cloud (free, 1000+ tok/sec) ─────────────────────────────────
# Sign up: https://cloud.cerebras.ai — no credit card
# Best free large model: llama-3.3-70b
CEREBRAS_API_KEY=
CEREBRAS_DEFAULT_MODEL=llama-3.3-70b


# ── SambaNova Cloud (free, largest free models) ───────────────────────────
# Sign up: https://cloud.sambanova.ai — no credit card
# Has Llama 3.1 405B free — the largest freely available model anywhere
SAMBANOVA_API_KEY=
SAMBANOVA_DEFAULT_MODEL=Meta-Llama-3.3-70B-Instruct


# ── Google Gemini (best free tier 2 option) ───────────────────────────────
# Get key: https://aistudio.google.com — no billing required
# gemini-1.5-flash: 15 RPM, 1,000,000 tokens/day FREE
# gemini-2.0-flash-exp is also excellent and free
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-1.5-flash


# ── OpenRouter (free :free models) ───────────────────────────────────────
# Sign up: https://openrouter.ai — free models, no credit card
# Good free options (append :free):
#   meta-llama/llama-3.3-70b-instruct:free
#   microsoft/phi-3-medium-128k-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free


# ── DeepSeek (near-free paid) ────────────────────────────────────────────
# Sign up: https://platform.deepseek.com
# DeepSeek-V3: ~$0.07/1M input tokens — practically free for dev
# deepseek-reasoner (R1): strong reasoning, good for planning
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat


# ── Anthropic Claude (paid, tier 3 only) ─────────────────────────────────
# Only used when TIER3_ENABLED=true
# claude-haiku-4-5-20251001: $0.25/$1.25 per 1M tokens — cheapest Claude
# claude-sonnet-4-6:         $3/$15 per 1M tokens — best quality
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_SECONDS=120


# ── Mistral (free experimental tier) ─────────────────────────────────────
# Sign up: https://console.mistral.ai — limited free tier
MISTRAL_API_KEY=
MISTRAL_DEFAULT_MODEL=mistral-small-latest


# ============================================================================
# VALIDATION TUNING
# ============================================================================
# Scale factor applied to all per-task validation thresholds.
# 1.0 = full thresholds (calibrated for 70B+ or Claude-class models)
# 0.75 = suitable for 13B-30B models
# 0.60 = minimum viable for 7B local models
#
# Lower this if EVERY task fails and you're using small local models.
# Keep at 1.0 once you have good free providers (Gemini, Cerebras, etc.)
VALIDATION_SCORE_SCALE=1.0


# ============================================================================
# ORCHESTRATION
# ============================================================================
# For local Ollama: set to 1-2 (one request at a time)
# For fast cloud APIs (Groq, Cerebras, Gemini): 4-8 is fine
MAX_CONCURRENT_TASKS=4
TASK_DEFAULT_RETRY_LIMIT=3


# ============================================================================
# DATABASE + VECTOR STORE
# ============================================================================
DATABASE_URL=sqlite+aiosqlite:///./engine.db
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data
